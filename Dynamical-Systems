import numpy as np
import matplotlib.pyplot as plt
from scipy.integrate import solve_ivp
from scipy.interpolate import interp1d


# ============================================================
# --- MODELS (Add Your Own) ---
# ============================================================

def simple_pendulum(t, y, p):
    theta, omega = y
    
    dtheta = omega
    domega = -(p['g']/p['l'])*np.sin(theta)
    
    return [dtheta, domega]


def double_pendulum(t, y, p):

    t1, w1, t2, w2 = y

    delta = t2 - t1

    den = (
        (p['m1'] + p['m2']) * p['L1']
        - p['m2'] * p['L1'] * np.cos(delta)**2
    )

    dw1 = (
        p['m2'] * p['L1'] * w1**2 * np.sin(delta) * np.cos(delta)
        + p['m2'] * p['g'] * np.sin(t2) * np.cos(delta)
        + p['m2'] * p['L2'] * w2**2 * np.sin(delta)
        - (p['m1'] + p['m2']) * p['g'] * np.sin(t1)
    ) / den

    dw2 = (
        -p['m2'] * p['L2'] * w2**2 * np.sin(delta) * np.cos(delta)
        + (p['m1'] + p['m2']) * p['g'] * np.sin(t1) * np.cos(delta)
        - (p['m1'] + p['m2']) * p['L1'] * w1**2 * np.sin(delta)
        - (p['m1'] + p['m2']) * p['g'] * np.sin(t2)
    ) / ((p['L2']/p['L1']) * den)

    return [w1, dw1, w2, dw2]


def duffing(t, y, p):
    x, v = y
    return [v, -p['k'] * v + x - x**3 + p['F0'] * np.cos(p['w'] * t)]

# ============================================================
# --- ENERGY ---
# ============================================================

def calculate_energy(sol, model_func, p):
    y = sol.y
    model_name = model_func.__name__
        
    if model_name == "simple_pendulum":
        theta, omega = y
        T = 0.5 * p['m1'] * (p['l'] * omega)**2
        V = p['m1'] * p['g'] * p['l'] * (1 - np.cos(theta))
    
    elif model_name == "double_pendulum":
        t1, w1, t2, w2 = y
        m1, m2, L1, L2, g = p['m1'], p['m2'], p['L1'], p['L2'], p['g']
        
        T1 = 0.5 * m1 * (L1 * w1)**2
        T2 = 0.5 * m2 * ((L1 * w1)**2 + (L2 * w2)**2 + 2 * L1 * L2 * w1 * w2 * np.cos(t1 - t2))
        T = T1 + T2
        
        V1 = -m1 * g * L1 * np.cos(t1)
        V2 = -m2 * g * (L1 * np.cos(t1) + L2 * np.cos(t2))
        V = V1 + V2 + (m1 + m2) * g * L1 + m2 * g * L2
        
    else:
        return None, None, None
        
    return T, V, T + V


