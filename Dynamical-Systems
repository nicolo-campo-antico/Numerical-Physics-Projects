# ============================================================
# --- GLOBAL PARAMETERS ---
# ============================================================

global_params = {

    "g": 9.81, "l": 1.0,
    
    "m1": 1.0, "m2": 1.0,
    
    "L1": 1.0, "L2": 1.0,
    
    'k': 1000.0,
    
    "F0": 0.3, "w": 1.2,
    
}


# ============================================================
# --- CONFIGURATION ---
# ============================================================

config = {

    "model": double_pendulum,
    
    "method": "RK45",
    
    ### FORMAT: y0 = [q1, v1, q2, v2, ..., qN, vN] ###
    
    "y0": [np.pi/2, 0.0,
           0.0, 0.0], 
    
    "labels": [r"$\theta_1$", r"$\omega_1$",
               r"$\theta_2$", r"$\omega_2$"],

    "t_span": (0, 50),

    # --- Poincaré selector ---
    "use_poincare": False,

    # Solo se attivo
    "poincare_period":
        2*np.pi / global_params["w"]

}


# ============================================================
# --- EXECUTION ---
# ============================================================

sol = run_simulation(

    config["model"],

    config["y0"],

    config["t_span"],

    global_params,

    config["labels"],
    
    method=config["method"]

)


# ============================================================
# --- PLOT ---
# ============================================================

plot_results(
    sol, 
    config["labels"], 
    config["model"], 
    global_params
)



plot_phase_space(
    sol, 
    config["labels"]
)

if config["use_poincare"]:
    plot_poincare(
        sol,
        config["labels"],
        config["poincare_period"]
    )
